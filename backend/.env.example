# Transaction pooler (port 6543) — used by Prisma at runtime; pgbouncer=true disables prepared statements
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# Session pooler or direct connection (port 5432) — used by Prisma migrate/db push
DIRECT_URL="postgresql://user:password@host:5432/postgres"

PORT=3001
